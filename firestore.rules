rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // MVP shared-company rules: any signed-in user can read/write company app data.
    // Later, lock this down by checking a users/{uid}.companyId membership record.
    match /companies/{companyId}/appData/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
